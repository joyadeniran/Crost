# ============================================================
# CROST ENVIRONMENT CONFIGURATION
# Copy this to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# --- LLM ROUTING ---
ENV_MODE=cloud                                  # 'local' | 'cloud' (cloud-only for now)

# --- LITELLM PROXY ---
LITELLM_URL=http://localhost:4000               # LiteLLM proxy URL
LITELLM_KEY=your_litellm_master_key             # Set in litellm_config.yaml

# --- CLOUD MODELS (used by onyx-client.ts) ---
CLOUD_MODEL=gemini/gemini-1.5-pro               # Orchestrator + marketing worker
CLOUD_MODEL_WORKER=gemini/gemini-1.5-pro        # Sales + ops workers

# --- CLOUD LLM KEYS ---
GEMINI_API_KEY=your_google_ai_studio_key        # Primary cloud model
ANTHROPIC_API_KEY=your_key_here                 # Fallback / claude-sonnet
GROQ_API_KEY=your_key_here                      # Optional: fast cloud inference

# --- LOCAL LLM (Ollama) ---
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_DEFAULT_MODEL=gemma3:12b
OLLAMA_FALLBACK_MODEL=llama3:8b
OLLAMA_LITE_MODEL=mistral

# --- SUPABASE ---
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key  # Server-side only — NEVER expose to client

# --- ONYX ENGINE ---
ONYX_API_URL=http://localhost:8080
ONYX_API_KEY=your_onyx_internal_api_key
ONYX_INTERNAL_URL=http://onyx-backend:8080       # Docker internal network URL

# --- TOOL CONNECTORS ---
GITHUB_TOKEN=your_github_pat
GMAIL_CLIENT_ID=your_oauth_client_id
GMAIL_CLIENT_SECRET=your_oauth_client_secret
SLACK_BOT_TOKEN=xoxb-your-token

# --- SYSTEM ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
