# ─── Google Cloud Platform ───────────────────────────────────────────────────
# Cloud SQL connection string (from gcp-setup.sh output)
DATABASE_URL=postgresql://crost:password@/crost?host=/cloudsql/project:region:instance

# GCS bucket for file storage
GCS_BUCKET=crost-app-storage
GCP_PROJECT_ID=crost-app

# ─── Firebase Auth ────────────────────────────────────────────────────────────
# Server-side (secret): from Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"

# Client-side (public): from Firebase Console → Project Settings → Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=your-web-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# ─── Gemini AI (Google Cloud Vertex AI) ──────────────────────────────────────
# Get from: https://aistudio.google.com/apikey
GOOGLE_AI_STUDIO_API_KEY=AIza...
GEMINI_API_KEY=AIza...  # alias

# ─── Default Models (Gemini-first) ────────────────────────────────────────────
CLOUD_MODEL=gemini/gemini-2.0-flash
CLOUD_MODEL_WORKER=gemini/gemini-2.0-flash

# ─── Application URL ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Composio Tool Sandbox ────────────────────────────────────────────────────
COMPOSIO_API_KEY=your-composio-api-key

# ─── Internal Secrets ─────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
WORKER_INTERNAL_SECRET=generate-with-openssl-rand-hex-32
CRON_SECRET=generate-with-openssl-rand-hex-32

# ─── Legacy (no longer required post-GCP migration) ──────────────────────────
# NEXT_PUBLIC_SUPABASE_URL=  (removed)
# SUPABASE_SERVICE_ROLE_KEY= (removed)
# LITELLM_BASE_URL=          (removed)
# LITELLM_MASTER_KEY=        (removed)
