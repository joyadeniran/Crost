# ─── Supabase ────────────────────────────────────────────────────────────────
# These run your core DB and Auth APIs. Look in your Supabase project settings.
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-role-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Application App URLs ────────────────────────────────────────────────────
# The URL where your application is running. Crucial for callbacks and worker processes.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Worker API Base URLs ────────────────────────────────────────────────────
# Base URLs for your external proxy backends / local orchestration loops.
LITELLM_BASE_URL=http://localhost:4000
LITELLM_MASTER_KEY=sk-your-master-key-here
OLLAMA_BASE_URL=http://localhost:11434

# ─── Multi-Agent Models Configuration ────────────────────────────────────────
# Fallback models when user has no model assignments configured.
# Names must match model_name entries in litellm/config.yaml model_list.
# Options: groq/llama-3.3-70b-versatile | gemini/gemini-2.5-flash |
#          anthropic/claude-sonnet-4.6  | anthropic/claude-opus-4.6
CLOUD_MODEL=groq/llama-3.3-70b-versatile
CLOUD_MODEL_WORKER=groq/llama-3.3-70b-versatile
ENV_MODE=production

# ─── API Keys (Passed to LiteLLM via env or config) ──────────────────────────
GOOGLE_AI_STUDIO_API_KEY=your-gemini-key
GROQ_API_KEY=your-groq-key
ANTHROPIC_API_KEY=your-anthropic-key

# ─── Composio Tool Sandbox ───────────────────────────────────────────────────
COMPOSIO_API_KEY=your-composio-api-key

# ─── Internal Worker Secret ───────────────────────────────────────────────────
# Dedicated bearer for server-to-server calls via x-crost-internal-secret header.
# Generate with: openssl rand -hex 32
# Falls back to SUPABASE_SERVICE_ROLE_KEY if unset (set this to rotate away from service key).
WORKER_INTERNAL_SECRET=generate-with-openssl-rand-hex-32

# ─── Cron Secret ─────────────────────────────────────────────────────────────
# Required for POST /api/approvals/expire. Must match x-cron-secret header.
# Generate with: openssl rand -hex 32
CRON_SECRET=generate-with-openssl-rand-hex-32
