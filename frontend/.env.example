# ─── Supabase ────────────────────────────────────────────────────────────────
# These run your core DB and Auth APIs. Look in your Supabase project settings.
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-role-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Application App URLs ────────────────────────────────────────────────────
# The URL where your application is running. Crucial for callbacks and worker processes.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Worker API Base URLs ────────────────────────────────────────────────────
# Base URLs for your external proxy backends / local orchestration loops.
ONYX_BASE_URL=http://localhost:3000
LITELLM_BASE_URL=http://localhost:4000
OLLAMA_BASE_URL=http://localhost:11434

# ─── Multi-Agent Models Configuration ────────────────────────────────────────
# Defines the models the orchestration worker will use.
CLOUD_MODEL=gemini-2.5-pro
CLOUD_MODEL_WORKER=gemini-2.5-flash
# Optional overrides depending on the deployed environment
LOCAL_MODEL=llama3.1
ENV_MODE=production

# ─── API Keys ────────────────────────────────────────────────────────────────
# Keys to use for all inference models requested by your AI Orchestrator
GOOGLE_AI_STUDIO_API_KEY=your-gemini-key-from-google-ai-studio
GROQ_API_KEY=your-groq-key
LITELLM_KEY=sk-1234
ONYX_API_KEY=your-onyx-key-if-required

# ─── Composio Tool Sandbox ───────────────────────────────────────────────────
# Crucial connection integration platform to run third-party tools natively
COMPOSIO_API_KEY=your-composio-api-key
